# PixelCraft Environment Variables
# Copy this file to .env and fill in the values

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/pixelcraft?schema=public"

# NextAuth (for admin authentication - optional)
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (for contact form - optional)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="hello@pixelcraft.studio"

# Analytics (optional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
